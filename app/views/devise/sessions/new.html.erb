<div class="min-h-screen bg-gradient-to-br from-cyan-50 to-blue-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-xl shadow-lg p-8">
      <h1 class="text-3xl font-bold text-slate-800 mb-2 text-center">ログイン</h1>
      <p class="text-center text-slate-600 mb-8">上面図管理システムにアクセス</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent" %>
          </div>

          <div>
            <%= f.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-2" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-transparent" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "w-4 h-4 text-cyan-600 rounded focus:ring-cyan-500" %>
              <%= f.label :remember_me, "ログイン状態を保存", class: "ml-2 text-sm text-slate-600" %>
            </div>
          <% end %>

          <div class="pt-2">
            <%= f.submit "ログイン", class: "w-full py-2 px-4 bg-cyan-600 text-white font-medium rounded-lg hover:bg-cyan-700 transition-colors" %>
          </div>
        </div>
      <% end %>

      <div class="mt-8 pt-8 border-t border-slate-200">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
