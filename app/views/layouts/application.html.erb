<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="/manifest.json">

    <%# PWA meta tags %>
    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="FloorMap">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%# In development, Vite handles CSS via application.jsx import %>
    <% unless Rails.env.development? %>
      <%= stylesheet_link_tag :app %>
    <% end %>

    <%# Vite client and application entry point %>
    <% if Rails.env.development? %>
      <script type="module" src="http://localhost:3036/vite-dev/@vite/client"></script>
      <script type="module" src="http://localhost:3036/vite-dev/app/javascript/entrypoints/application.jsx"></script>
    <% end %>
  </head>

  <body>
    <%= render 'shared/header' %>

    <div id="app">
      <%= yield %>
    </div>
  </body>
</html>