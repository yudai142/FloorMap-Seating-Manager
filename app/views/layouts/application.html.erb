<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="/manifest.json">

    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="FloorMap">

    <%# Vite Assets %>
    <%
      manifest_path = Rails.root.join('public/vite-dev/.vite/manifest.json')
      manifest_content = File.read(manifest_path) rescue nil
      manifest = manifest_content ? JSON.parse(manifest_content) : {}
      app_manifest = manifest['entrypoints/application.jsx'] || {}
    %>
    <!-- DEBUG: manifest_path=<%= manifest_path %> exists=<%= File.exist?(manifest_path) %> app_manifest=<%= app_manifest.inspect %> -->
    <% if app_manifest['css'] %>
      <% app_manifest['css'].each do |css_file| %>
        <link rel="stylesheet" href="/vite-dev/<%= css_file %>">
      <% end %>
    <% end %>
    <% if app_manifest['file'] %>
      <script type="module" src="/vite-dev/<%= app_manifest['file'] %>"></script>
    <% end %>
  </head>

  <body>
    <%
      manifest_path = Rails.root.join('public/vite-dev/.vite/manifest.json')
      manifest_debug = {
        path: manifest_path.to_s,
        exists: File.exist?(manifest_path),
        app_manifest: app_manifest
      }
    %>
    <!-- MANIFEST_DEBUG: <%= manifest_debug.to_json %> -->
    <% if @inertia %>
      <div id="app" data-page="<%= @inertia.to_json %>"></div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>