<header class="bg-slate-900 text-white px-4 py-3 flex items-center justify-between shadow-md">
  <a href="/" class="font-semibold text-lg hover:text-cyan-400 transition-colors">
    FloorMap Seating Manager
  </a>

  <button id="new-room-btn"
    class="px-3 py-1.5 bg-cyan-500 text-slate-900 font-medium rounded-lg
           hover:bg-cyan-400 transition-colors text-sm">
    新規作成
  </button>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('new-room-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var el = document.getElementById('new-room-form');
      if (!el) {
        // ページにフォームがない場合はルートにスクロール
        window.location.href = '/';
        return;
      }
      el.style.display = (el.style.display === 'none' || el.style.display === '') ? 'block' : 'none';
      el.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
