<header style="background:#0f172a;color:#fff;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;">
  <div style="font-weight:600;font-size:18px;">FloorMap Seating Manager</div>

  <div>
    <button id="new-room-btn" style="background:#06b6d4;color:#042f2e;border:none;padding:8px 12px;border-radius:6px;cursor:pointer;">
      上面図を新規作成
    </button>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('new-room-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var el = document.getElementById('new-room-form');
      if (!el) {
        // ページにフォームがない場合はルートにスクロール
        window.location.href = '/';
        return;
      }
      el.style.display = (el.style.display === 'none' || el.style.display === '') ? 'block' : 'none';
      el.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
