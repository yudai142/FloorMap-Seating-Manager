<h1><%= @room.name %></h1>

<p>Size: <%= @room.width %> x <%= @room.height %></p>

<h2>Seats</h2>
<ul>
  <% @room.seats.each do |seat| %>
    <li><%= "Seat ##{seat.id} - (#{seat.x}, #{seat.y}) - #{seat.occupied ? 'Occupied' : 'Free'}" %></li>
  <% end %>
</ul>

<p>Fallback ERB page (no Inertia).</p>
