<h1>Rooms</h1>
<ul>
  <% @rooms.each do |room| %>
    <li>
      <a href="<%= room_path(room) %>"><%= room.name %></a>
      (<%= room.width %> x <%= room.height %>)
    </li>
  <% end %>
</ul>

<p>
  This is the fallback ERB view used when Inertia is not available.
</p>

<!-- New room form (hidden by default, toggled by header button) -->
<div id="new-room-form" style="display:none;margin-top:16px;padding:12px;border:1px solid #e5e7eb;border-radius:6px;max-width:480px;">
  <h2>上面図を新規作成</h2>

  <%= form_with model: Room.new, local: true do |f| %>
    <div style="margin-bottom:8px;">
      <%= f.label :name, '名前' %><br>
      <%= f.text_field :name, required: true, style: 'width:100%;padding:8px;border:1px solid #cbd5e1;border-radius:4px;' %>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:8px;">
      <div style="flex:1;">
        <%= f.label :width, '幅' %><br>
        <%= f.number_field :width, value: 800, required: true, style: 'width:100%;padding:8px;border:1px solid #cbd5e1;border-radius:4px;' %>
      </div>
      <div style="flex:1;">
        <%= f.label :height, '高さ' %><br>
        <%= f.number_field :height, value: 600, required: true, style: 'width:100%;padding:8px;border:1px solid #cbd5e1;border-radius:4px;' %>
      </div>
    </div>

    <div>
      <%= f.submit '作成', style: 'background:#06b6d4;color:#042f2e;border:none;padding:8px 12px;border-radius:6px;cursor:pointer;' %>
    </div>
  <% end %>
</div>
