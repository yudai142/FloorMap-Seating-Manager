# Database
DATABASE_URL=postgresql://user:password@localhost:5432/floormap_development

# Redis configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# AWS S3 (for Active Storage in production)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Email configuration (for Devise and notifications)
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# Application settings
RAILS_ENV=development
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here

# Devise
DEVISE_JWT_SECRET_KEY=your_jwt_secret_key

# Sentry (error tracking - optional)
SENTRY_DSN=your_sentry_dsn

# Sidekiq (background jobs)
SIDEKIQ_CONCURRENCY=5
SIDEKIQ_THREADS=5

# Session timeout (in hours)
SESSION_TIMEOUT=2
