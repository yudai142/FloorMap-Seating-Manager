# Rails
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_from_config/master.key
SECRET_KEY_BASE=your_secret_key_base

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/floormap_production

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# AWS S3 (Active Storage)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=floormap-production-bucket

# Email (SMTP)
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key
MAIL_FROM=noreply@floormap.example.com

# Security
RAILS_HOSTNAME=floormap.example.com
FORCE_SSL=true

# Sidekiq Web UI
SIDEKIQ_USERNAME=admin
SIDEKIQ_PASSWORD=your_secure_password

# Sentry (Error tracking - optional)
SENTRY_DSN=your_sentry_dsn

# Session timeout (hours)
SESSION_TIMEOUT=2

# API Rate Limiting
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW=60

# Log Level
LOG_LEVEL=info
